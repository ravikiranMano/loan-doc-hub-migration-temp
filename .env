# ─── Node API (Migration flags) ───────────────────────────────────────────────
# Comma-separated list of domains to route through Node API.
# Values: system | admin | contacts | documents | deals | all
# Leave empty → everything uses Supabase (safe default)
VITE_USE_NODE_API="system,admin,contacts,documents,deals"
VITE_NODE_API_URL="http://localhost:3000/api"

# ─── Supabase (frontend-safe keys only — service_role lives in backend/.env) ──
