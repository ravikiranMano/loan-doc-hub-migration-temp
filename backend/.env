# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
# Must be an explicit origin (not *) when credentials: include is used
# Must match the Vite dev server origin (credentials + cookies)
CORS_ORIGIN=http://localhost:8080

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Pooled connection — used by Prisma Client at runtime (pgbouncer=true)
DATABASE_URL="postgresql://postgres.pibqnspfzqylceyonkia:BvA67%2FH%234Md4fnY@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — used by Prisma CLI (db pull, migrate)
DIRECT_URL="postgresql://postgres.pibqnspfzqylceyonkia:BvA67%2FH%234Md4fnY@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# ─── JWT (own auth — not Supabase) ───────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-jwt-secret-min-64-chars"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

