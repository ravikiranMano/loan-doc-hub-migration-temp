# =============================================================================
# Loan Doc Hub — NestJS Backend (.gitignore)
# Standalone repo: copy .env.example → .env (never commit secrets).
# After clone: npm install && npm run db:generate
# =============================================================================

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Build output ─────────────────────────────────────────────────────────────
dist/
*.tsbuildinfo

# ── Generated Prisma client (rebuild: npm run db:generate) ───────────────────
src/generated/

# ── Environment & secrets (NEVER commit) ─────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# Keys, certs, local credential dumps
*.pem
*.key
*.p12
credentials.json
secrets.json

# ── Logs & runtime ───────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Test & coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/
junit.xml

# ── One-off script artifacts (keep scripts/*.ts source) ───────────────────────
scripts/**/output/
scripts/**/*.docx
scripts/**/*.xml
!scripts/**/README.md

# ── Temp & cache ─────────────────────────────────────────────────────────────
tmp/
temp/
.cache/
.eslintcache

# ── Supabase CLI (if edge functions / local stack added later) ───────────────
supabase/.temp/
supabase/.branches/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editors & local AI tooling ─────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

.claude/
.cursor/

# ── Accidental / editor junk at repo root ────────────────────────────────────
prismaschema.prisma:*
