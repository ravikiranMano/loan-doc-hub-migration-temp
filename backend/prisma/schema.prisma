generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model activity_log {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_id        String   @db.Uuid
  actor_user_id  String   @db.Uuid
  action_type    String
  action_details Json?
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  deals          deals    @relation(fields: [deal_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_activity_log_created_at")
  @@index([deal_id], map: "idx_activity_log_deal_id")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model borrower_attachments {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contact_id     String   @db.Uuid
  file_name      String
  file_path      String
  file_type      String?
  file_size      String?
  category       String   @default("Miscellaneous")
  description    String?
  uploaded_by    String   @db.Uuid
  uploaded_at    DateTime @default(now()) @db.Timestamptz(6)
  version_number Int      @default(1)
  status         String   @default("active")
  contacts       contacts @relation(fields: [contact_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([contact_id], map: "idx_borrower_attachments_contact_id")
  @@schema("public")
}

model contacts {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contact_id           String                 @unique(map: "contacts_contact_id_unique")
  contact_type         String
  first_name           String?
  last_name            String?
  full_name            String?
  company              String?
  email                String?
  phone                String?
  city                 String?
  state                String?
  contact_data         Json?
  created_by           String                 @db.Uuid
  created_at           DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?              @default(now()) @db.Timestamptz(6)
  borrower_attachments borrower_attachments[]
  users                users                  @relation(fields: [created_by], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([contact_type], map: "idx_contacts_contact_type")
  @@index([created_by], map: "idx_contacts_created_by")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model conversation_log_types {
