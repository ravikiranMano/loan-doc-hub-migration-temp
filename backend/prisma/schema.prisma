  users               users?                @relation(fields: [created_by], references: [id], onUpdate: NoAction)

  @@unique([name, state, product_type, version], map: "idx_templates_version_unique")
  @@unique([name, state, product_type, version])
  @@index([state, product_type], map: "idx_templates_state_product")
  @@schema("public")
}

model user_form_permissions {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String   @db.Uuid
  form_key    String
  access_mode String   @default("view_only")
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)

  @@unique([user_id, form_key])
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model user_permission_levels {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String   @unique @db.Uuid
  permission_level String   @default("full")
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id], map: "idx_user_permission_levels_user")
  @@schema("public")
}

model users {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String              @unique
  password_hash     String              @default("")
  full_name         String?
  phone             String?
  company           String?
  license_number    String?
  user_type         String              @default("internal")
  role              app_role            @default(other)
  is_active         Boolean             @default(true)
  last_sign_in_at   DateTime?           @db.Timestamptz(6)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  contacts          contacts[]
  deal_field_values deal_field_values[]
  deal_participants deal_participants[]
  deals             deals[]
  packets           packets[]
  refresh_tokens    refresh_tokens[]
  templates         templates[]

  @@index([email], map: "idx_users_email")
  @@index([is_active], map: "idx_users_is_active")
  @@index([role], map: "idx_users_role")
  @@index([user_type], map: "idx_users_user_type")
  @@schema("public")
}

