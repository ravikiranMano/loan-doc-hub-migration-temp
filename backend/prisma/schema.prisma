  display_order Int      @default(0)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  @@schema("public")
}

model deal_assignments {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_id     String   @db.Uuid
  user_id     String   @db.Uuid
  role        app_role
  assigned_by String   @db.Uuid
  assigned_at DateTime @default(now()) @db.Timestamptz(6)
  notes       String?
  deals       deals    @relation(fields: [deal_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([deal_id, user_id])
  @@schema("public")
}

model deal_field_values {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_id             String    @db.Uuid
  value_text          String?
  value_number        Decimal?  @db.Decimal
  value_date          DateTime? @db.Date
  value_json          Json?
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_by          String?   @db.Uuid
  field_dictionary_id String?   @db.Uuid
  deals               deals     @relation(fields: [deal_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users?    @relation(fields: [updated_by], references: [id], onUpdate: NoAction)

  @@unique([deal_id, field_dictionary_id])
  @@index([deal_id], map: "idx_deal_field_values_deal_id")
  @@index([field_dictionary_id], map: "idx_deal_field_values_dict_id")
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model deal_participants {
  id             String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_id        String                    @db.Uuid
  role           app_role
  user_id        String?                   @db.Uuid
  access_method  participant_access_method @default(login)
  sequence_order Int?
  status         participant_status        @default(invited)
  invited_at     DateTime                  @default(now()) @db.Timestamptz(6)
  completed_at   DateTime?                 @db.Timestamptz(6)
  created_at     DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime                  @default(now()) @db.Timestamptz(6)
  email          String?
  name           String?
  revoked_at     DateTime?                 @db.Timestamptz(6)
  phone          String?
  contact_id     String?                   @db.Uuid
  deals          deals                     @relation(fields: [deal_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          users?                    @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  magic_links    magic_links[]

  @@index([deal_id], map: "idx_deal_participants_deal_id")
  @@index([email], map: "idx_deal_participants_email")
  @@index([status], map: "idx_deal_participants_status")
  @@index([user_id], map: "idx_deal_participants_user_id", where: raw("(user_id IS NOT NULL)"))
  @@schema("public")
}

model deal_section_values {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_id      String        @db.Uuid
  section      field_section
  field_values Json          @default("{}")
  updated_at   DateTime      @default(now()) @db.Timestamptz(6)
  version      Int           @default(1)
  deals        deals         @relation(fields: [deal_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([deal_id, section], map: "deal_section_values_unique")
  @@index([deal_id], map: "idx_deal_section_values_deal_id")
  @@index([field_values], map: "idx_deal_section_values_field_values", type: Gin)
  @@schema("public")
}

model deals {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_number         String                @unique
  state               String?               @default("TBD")
  product_type        String?               @default("TBD")
  packet_id           String?               @db.Uuid
  mode                deal_mode             @default(doc_prep)
  status              deal_status           @default(draft)
  borrower_name       String?
  property_address    String?
  loan_amount         Decimal?              @db.Decimal(15, 2)
  notes               String?
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  created_by          String                @db.Uuid
  activity_log        activity_log[]
  deal_assignments    deal_assignments[]
  deal_field_values   deal_field_values[]
  deal_participants   deal_participants[]
  deal_section_values deal_section_values[]
  users               users                 @relation(fields: [created_by], references: [id], onDelete: SetNull, onUpdate: NoAction)
  packets             packets?              @relation(fields: [packet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  event_journal       event_journal[]
  generated_documents generated_documents[]
  generation_jobs     generation_jobs[]
  loan_history        loan_history[]
  messages            messages[]

  @@index([created_by], map: "idx_deals_created_by")
  @@index([packet_id], map: "idx_deals_packet_id")
  @@index([state], map: "idx_deals_state")
  @@index([status], map: "idx_deals_status")
  @@schema("public")
}

model event_journal {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_id       String   @db.Uuid
  event_number  Int      @default(0)
  actor_user_id String   @db.Uuid
  section       String
  details       Json     @default("[]")
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  ip_address    String?
  deals         deals    @relation(fields: [deal_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([deal_id, event_number(sort: Desc)], map: "idx_event_journal_deal")
  @@schema("public")
}

