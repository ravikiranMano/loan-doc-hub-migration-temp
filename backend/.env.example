# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
# Must be an explicit origin (not *) when credentials: include is used
CORS_ORIGIN=http://localhost:5173

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Pooled connection — used by Prisma Client at runtime (pgbouncer=true)
DATABASE_URL="postgresql://postgres.[project-ref]:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — used by Prisma CLI (db pull, migrate)
DIRECT_URL="postgresql://postgres.[project-ref]:[PASSWORD]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# ─── JWT (own auth — not Supabase) ───────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-jwt-secret-min-64-chars"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7

# ─── Supabase (Storage proxy + bridge until S3 migration) ────────────────────
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
# Dashboard → Project Settings → API → service_role key (server-side only, never expose)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Optional: Dashboard → API → JWT Settings → Legacy JWT secret (NOT the same as JWT_SECRET above)
# If unset, generate-document uses service_role + X-User-Id (requires deployed edge).
# SUPABASE_JWT_SECRET="your-32+-char-supabase-jwt-secret"
